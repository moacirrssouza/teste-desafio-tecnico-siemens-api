# Environment variables for Docker Compose
# Copy this file to .env and customize values

# PostgreSQL Configuration
POSTGRES_DB=BookManagementDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# Connection string will be built as:
# Host=postgres;Port=5432;Database=BookManagementDb;Username=postgres;Password=postgres

# Optional: For HTTPS certificates (self-signed)
# ASPNETCORE_HTTPS_PORT=5001
# ASPNETCORE_Kestrel__Certificates__Default__Path=/https/aspnetapp.pfx
# ASPNETCORE_Kestrel__Certificates__Default__Password=YourCertificatePassword
